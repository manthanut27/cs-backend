#!/usr/bin/env node

const app = require('../app');
const http = require('http');
const { setupWebSocket } = require('../ws/WebSocketServer');
const logger = require('../utils/logger');

const port = parseInt(process.env.PORT || '3001', 10);
app.set('port', port);

const server = http.createServer(app);

// Attach WebSocket server
setupWebSocket(server);

// Start background services (graceful — won't crash if they fail)
try {
  const FileService = require('../services/FileService');
  FileService.startAllWatchers();
  logger.info('File watchers started');
} catch (err) {
  logger.warn('File watcher init skipped:', err.message);
}

try {
  const LogService = require('../services/LogService');
  LogService.startLogTail();
  logger.info('Log tailer started');
} catch (err) {
  logger.warn('Log tailer init skipped:', err.message);
}

server.listen(port, '127.0.0.1', () => {
  logger.info(`🛡  CyberSec Toolkit running on http://127.0.0.1:${port}`);
  logger.info(`   API:   http://127.0.0.1:${port}/api`);
});

server.on('error', (error) => {
  if (error.syscall !== 'listen') throw error;
  const bind = `Port ${port}`;
  switch (error.code) {
    case 'EACCES':
      logger.error(`${bind} requires elevated privileges`);
      process.exit(1);
      break;
    case 'EADDRINUSE':
      logger.error(`${bind} is already in use`);
      process.exit(1);
      break;
    default:
      throw error;
  }
});
